# ==============================================================================
# VARIÁVEIS CLIENT-SIDE (Frontend - incluídas no bundle JavaScript)
# Essas são SEGURAS para expor — o Firebase foi projetado para usar no client.
# ==============================================================================

# Firebase Configuration
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# ==============================================================================
# VARIÁVEIS SERVER-SIDE (Backend - NUNCA expostas no navegador)
# Configure essas APENAS no Vercel Dashboard → Settings → Environment Variables
# ==============================================================================

# Firebase Admin (para validar tokens no servidor)
FIREBASE_PROJECT_ID=""

# Token de acesso ao Portal (validado no servidor)
ACCESS_TOKEN="seu_token_secreto_aqui"

# Integrações Bitrix24 (webhooks protegidos no servidor)
BITRIX_WEBHOOK_WRITE_URL="https://seu-dominio.bitrix24.com.br/rest/USER_ID/TOKEN/crm.deal.add.json"
BITRIX_LIST_URL="https://seu-dominio.bitrix24.com.br/rest/USER_ID/TOKEN/crm.deal.list.json"

# Google Sheets (IDs protegidos no servidor)
SHEET_ID="ID_DA_SUA_PLANILHA_GOOGLE"
SHEET_TAB_USUARIOS="usuários"
SHEET_TAB_CR="CR 2025"
