rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }
    
    function isOwner(data) { 
      return isSignedIn() && data.userId == request.auth.uid; 
    }

    // --- Validation Blueprints ---
    function isValidPromisedCommission(data) {
      let requiredKeys = ['pvId', 'receivableId', 'amount', 'previsaoMes', 'previsaoAno', 'userId', 'status', 'stageName', 'requestedAt', 'updatedAt'];
      return data.keys().hasAll(requiredKeys) &&
             data.pvId is string && data.pvId.size() < 128 &&
             data.receivableId is string && data.receivableId.size() < 256 &&
             data.amount is number &&
             data.previsaoMes is string &&
             data.previsaoAno is string &&
             data.userId == request.auth.uid &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.stageName is string && data.stageName.size() < 256 &&
             data.requestedAt == request.time &&
             data.updatedAt == request.time &&
             (data.keys().hasAny(['isCollateral']) ? (data.isCollateral is bool) : true) &&
             (data.keys().hasAny(['collateralFor']) ? (data.collateralFor is string && data.collateralFor.size() < 256) : true) &&
             (data.keys().hasAny(['userRole']) ? (data.userRole is string && data.userRole.size() < 128) : true);
    }

    function isValidUpdate(data) {
      let allowedKeys = ['status', 'stageName', 'updatedAt', 'signatureData', 'signedAt', 'userRole', 'isCollateral', 'collateralFor'];
      let affected = data.diff(existing()).affectedKeys();
      
      return data.userId == request.auth.uid &&
             affected.hasOnly(allowedKeys) &&
             incoming().userId == existing().userId &&
             incoming().receivableId == existing().receivableId &&
             incoming().pvId == existing().pvId &&
             (affected.hasAny(['status']) ? (data.status in ['pending', 'approved', 'rejected']) : true) &&
             (affected.hasAny(['stageName']) ? (data.stageName is string && data.stageName.size() < 256) : true) &&
             (affected.hasAny(['signatureData']) ? (data.signatureData is map) : true) &&
             (affected.hasAny(['signedAt']) ? (data.signedAt == request.time) : true) &&
             data.updatedAt == request.time;
    }

    function isValidResubmission(data) {
      return isValidPromisedCommission(data) &&
             data.userId == existing().userId &&
             data.receivableId == existing().receivableId &&
             data.pvId == existing().pvId;
    }

    // --- Resources ---
    match /promised_commissions/{commissionId} {
      // Secure Get: Only owner can read their own records
      allow get: if isOwner(existing());
      
      // Secure List: Query MUST be filtered by userId on the client side
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Secure Create: Validate ID and strict schema
      allow create: if isSignedIn() && 
                    isValidId(commissionId) && 
                    isValidPromisedCommission(request.resource.data);
      
      // Allow Status Updates or Full Re-Submission (e.g. from Rejected state)
      allow update: if isOwner(existing()) && 
                    (isValidUpdate(incoming()) || isValidResubmission(incoming()));
      
      // Allow delete if owner. Handle non-existent doc case to avoid PERMISSION_DENIED on no-op deletes
      allow delete: if isSignedIn() && (resource == null || isOwner(resource.data));
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /access_logs/{logId} {
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid &&
                    incoming().timestamp == request.time;
      // No read/update/delete allowed from client for audit logs
    }

    match /access_tokens/{tokenId} {
      allow get, create, delete: if tokenId is string && tokenId.size() <= 128;
    }
  }
}
